{
  "name": "@inflara/runner-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "pnpm run build:main && concurrently -k \"vite --host 127.0.0.1 --port 5178\" \"wait-on tcp:5178 && electron .\"",
    "build": "pnpm run build:main && vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inflara/agent-protocol": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "typescript": "^5",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  }
}
